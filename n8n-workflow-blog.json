        "language": "javascript",
        "code": "const body = $json.body || $json;\nconst message = body.message || {};\nconst text = message.text || '';\nconst replyTo = message.reply_to_message?.text || '';\n\n// Extract slug from the reply message\nconst slugMatch = replyTo.match(/\\*\\*Slug:\\*\\*\\s*(\\S+)/) || replyTo.match(/📌 Tema:\\s*(\\S+)/);\nconst slug = slugMatch ? slugMatch[1].trim() : '';\n\nconst aprovado = text.includes('/aprovar') || text.includes('/aprovar@');\n\nreturn [{ json: { slug, aprovado, text } }];"
