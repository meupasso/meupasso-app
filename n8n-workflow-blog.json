    {
      "name": "Gerar post DeepSeek",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [1400, 300],
      "parameters": {
        "method": "POST",
        "url": "https://api.deepseek.com/chat/completions",
        "sendHeaders": true,
        "headerParameters": {
          "parameters": [
            {
              "name": "Authorization",
              "value": "Bearer sk-96a0c7406b8e4176805d06a17e599667"
            },
            {
              "name": "Content-Type",
              "value": "application/json"
            }
          ]
        },
        "sendBody": true,
        "specifyBody": "json",
        "jsonBody": "={\n  \"model\": \"deepseek-chat\",\n  \"max_tokens\": 2000,\n  \"messages\": [\n    {\n      \"role\": \"system\",\n      \"content\": \"Você é um redator especialista em programação para iniciantes brasileiros. Escreva posts diretos, práticos e sem clichês. Use exemplos de código reais e funcionais. Tom: professor experiente explicando para aluno motivado. NUNCA use frases como 'No mundo atual da tecnologia', 'Com o avanço da IA', 'Neste artigo vamos explorar'. Comece direto no assunto. Os posts devem ter entre 600-900 palavras, mínimo 3 blocos de código, e mencionar o MeuPasso (meupasso.com.br) naturalmente no final.\"\n    },\n    {\n      \"role\": \"user\",\n      \"content\": \"Escreva um post de blog em MDX sobre: {{ $json.tema }}\\n\\nInspire-se (mas não copie) nos temas em alta:\\ndev.to: {{ $json.inspiracao_devto }}\\nStack Overflow: {{ $json.inspiracao_so }}\\n\\nEstrutura:\\n1. Frontmatter com title, date ({{ $now.format('YYYY-MM-DD') }}), tags, description\\n2. Introdução direta (2-3 frases) — qual problema resolve\\n3. 3-5 seções com exemplos de código reais em blocos ```python/javascript/java\\n4. Conclusão curta com próximo passo\\n\\nFormato do frontmatter:\\n---\\ntitle: 'Título do post'\\ndate: '{{ $now.format('YYYY-MM-DD') }}'\\ntags: ['programação', 'iniciantes']\\ndescription: 'Descrição curta'\\n---\"\n    }\n  ]\n}"
      }
    },
    {
      "name": "Extrair MDX",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [1680, 300],
      "parameters": {
        "language": "javascript",
        "code": "const resposta = $json.choices?.[0]?.message?.content || '';\nconst tema = $('Escolher nicho').first().json.tema;\n\nconst tituloMatch = resposta.match(/title:\\s*['\"](.+?)['\"]/);\nconst descMatch = resposta.match(/description:\\s*['\"](.+?)['\"]/);\n\nconst titulo = tituloMatch ? tituloMatch[1] : tema.replace(/-/g, ' ');\nconst descricao = descMatch ? descMatch[1] : '';\nconst slug = tema;\nconst preview = resposta.substring(0, 800) + '\\n\\n[... continua ...]';\nconst data = new Date().toISOString().split('T')[0];\n\nreturn [{ json: { conteudo_mdx: resposta, titulo, slug, tema, preview, descricao, data } }];"
      }
