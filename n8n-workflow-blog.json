    {
      "name": "Escolher nicho",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [1120, 300],
      "parameters": {
        "language": "javascript",
        "code": "const devtoItems = $('dev.to trending').all().map(i => i.json);\nconst soResponse = $('Stack Overflow hot').first().json;\nconst soItems = soResponse?.items || [];\nconst historicoItems = $('Buscar histórico Supabase').all().map(i => i.json?.tema).filter(Boolean);\n\nconst TEMAS_CURADOS = [\n  \"python-para-iniciantes-primeiros-passos\",\n  \"javascript-o-que-e-e-por-onde-comecar\",\n  \"java-para-iniciantes-guia-completo\",\n  \"logica-de-programacao-conceitos-essenciais\",\n  \"git-e-github-guia-pratico-para-iniciantes\",\n  \"algoritmos-basicos-que-todo-dev-deve-conhecer\",\n  \"poo-orientacao-a-objetos-explicada-simples\",\n  \"sql-basico-para-desenvolvedores-iniciantes\",\n  \"apis-rest-o-que-sao-e-como-usar\",\n  \"terminal-linux-comandos-essenciais-dev\",\n  \"vs-code-dicas-extensoes-para-programar\",\n  \"erros-comuns-python-como-corrigir\",\n  \"erros-comuns-java-como-corrigir\",\n  \"mercado-ti-brasil-salarios-vagas-2026\",\n  \"portfolio-github-como-montar-do-zero\",\n  \"primeiro-emprego-ti-como-conseguir\",\n  \"diferenca-frontend-backend-fullstack\",\n  \"como-aprender-programacao-mais-rapido\",\n  \"debugar-codigo-tecnicas-para-iniciantes\",\n  \"funcoes-python-guia-completo\",\n  \"arrays-listas-javascript-pratico\",\n  \"classes-objetos-java-exemplos\",\n  \"loops-for-while-quando-usar\",\n  \"condicionais-if-else-exemplos-reais\",\n  \"recursao-o-que-e-quando-usar\",\n  \"try-catch-tratamento-erros-programacao\",\n  \"modulos-imports-python-organizar-codigo\",\n  \"variaveis-tipos-dados-todas-linguagens\",\n  \"strings-manipulacao-python-javascript-java\",\n  \"dicionarios-objetos-mapas-programacao\"\n];\n\nconst temasUsados = historicoItems.slice(0, 30);\nconst temasDisponiveis = TEMAS_CURADOS.filter(t => !temasUsados.includes(t));\nconst lista = temasDisponiveis.length > 0 ? temasDisponiveis : TEMAS_CURADOS;\nconst tema = lista[Math.floor(Math.random() * lista.length)];\n\nconst inspiracao_devto = devtoItems.slice(0, 5).map(a => a.title).join(' | ');\nconst inspiracao_so = soItems.slice(0, 5).map(q => q.title).join(' | ');\n\nreturn [{ json: { tema, inspiracao_devto, inspiracao_so } }];"
      }
